# Deployed worker URL (or http://localhost:8787 for wrangler dev)
BENCH_URL=https://x402-parser-edge.YOUR_SUBDOMAIN.workers.dev

# Funded Base Sepolia private keys, comma-separated — TESTNET ONLY.
# One per benchmark document avoids the 50 req/hour/wallet rate limit.
# Never commit real keys; this file is the only one tracked by git.
BENCH_PRIVATE_KEYS=0xaaa...,0xbbb...,0xccc...
